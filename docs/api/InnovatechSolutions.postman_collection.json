            "url": {
              "raw": "{{keycloak}}/realms/innovatech/protocol/openid-connect/token",
              "host": [
                "{{keycloak}}"
              ],
              "path": [
                "realms",
                "innovatech",
                "protocol",
                "openid-connect",
                "token"
              ]
            },
            "description": "Obtiene el JWT desde Keycloak (password grant). Guarda el access_token en la variable {{token}}.",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "password"
                },
                {
                  "key": "client_id",
                  "value": "innovatech-frontend"
                },
                {
                  "key": "username",
                  "value": "ana@innovatech.cl"
                },
                {
                  "key": "password",
                  "value": "Secret.1"
                }
              ]
            }
          },
