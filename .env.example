# Plantilla de variables de entorno para desarrollo local.
# Copiar a .env y completar los valores. NUNCA commitear el .env real.

# Keycloak admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=<COMPLETAR>
KEYCLOAK_REALM=innovatech
KEYCLOAK_CLIENT_ID=innovatech-frontend

# Postgres dedicado para Keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=<COMPLETAR>

# PostgreSQL (una credencial por BD)
DB_PROJECTS_USER=projects_user
DB_PROJECTS_PASSWORD=<COMPLETAR>
DB_RESOURCES_USER=resources_user
DB_RESOURCES_PASSWORD=<COMPLETAR>
DB_ANALYTICS_USER=analytics_user
DB_ANALYTICS_PASSWORD=<COMPLETAR>
DB_ANALYTICS_NAME=analytics

# Snapshots de KPI (ms-analytics)
SNAPSHOTS_ENABLED=true
SNAPSHOTS_CRON=0 */5 * * * *
SNAPSHOTS_BACKFILL_WEEKS=12

# SMTP (dev → mailhog, prod → real)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=notificaciones@innovatech.cl

# Eureka
EUREKA_DEFAULT_ZONE=http://eureka-server:8761/eureka/

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<COMPLETAR>

# Frontend (Vite build-time vars). El bundle corre en el navegador del host,
# por eso los hosts son localhost y no nombres internos de la red docker.
VITE_API_BASE=http://localhost:9000/api
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=innovatech
VITE_KEYCLOAK_CLIENT_ID=innovatech-frontend
